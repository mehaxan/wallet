# Environment Variables — copy to .env.local and fill in values

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/wallet

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
JWT_SECRET=your-super-secret-key-change-this

# ─── Upstash Redis (free tier — https://upstash.com) ─────────────────────────
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ─── Google Gemini AI (https://ai.google.dev) ─────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key

# ─── Cloudflare R2 (receipt image storage) ───────────────────────────────────
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=wallet-receipts
R2_PUBLIC_URL=https://your-bucket.r2.dev

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
